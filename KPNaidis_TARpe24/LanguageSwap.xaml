<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KPNaidis_TARpe24.LanguageSwap"
             xmlns:vm="clr-namespace:KPNaidis_TARpe24.ViewModels"
             Title="LanguageSwap">
    <ContentPage.BindingContext>
        <vm:MainViewModel />
    </ContentPage.BindingContext>
    
    <VerticalStackLayout Padding="40" Spacing="25">
        <Label Text="{Binding Greeting}" 
               FontSize="32"
               HorizontalOptions="Center" />

        <Label Text="{Binding ChangeLanguageLabel}" 
               FontAttributes="Bold"
               FontSize="18"
               HorizontalOptions="Center" />


            <!-- English -->
            <Button Command="{Binding SetEnglishCommand}">
                <Button.ImageSource>
                    <FileImageSource File="britain.png" />
                </Button.ImageSource>
                <Button.Text>
                    <Binding Path="EnglishButton" />
                </Button.Text>
            </Button>

            <!-- Russian -->
            <Button Command="{Binding SetRussianCommand}">
                <Button.ImageSource>
                    <FileImageSource File="venemaa.png" />
                </Button.ImageSource>
                <Button.Text>
                    <Binding Path="RussianButton" />
                </Button.Text>
            </Button>

            <!-- Estonian -->
            <Button Command="{Binding SetEstonianCommand}">
                <Button.ImageSource>
                    <FileImageSource File="eesti.png" />
                </Button.ImageSource>
                <Button.Text>
                    <Binding Path="EstonianButton" />
                </Button.Text>
            </Button>


    </VerticalStackLayout>
</ContentPage>