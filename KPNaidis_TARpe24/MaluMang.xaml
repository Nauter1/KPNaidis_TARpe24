<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KPNaidis_TARpe24.MaluMang"
             Title="MaluMang">

    <AbsoluteLayout x:Name="RootLayout" Padding="10">

        <VerticalStackLayout AbsoluteLayout.LayoutBounds="0,0,1,0.3"
                             AbsoluteLayout.LayoutFlags="All"
                             Spacing="10">

            <Picker x:Name="ThemePicker" Title="Vali teema"/>

            <Button Text="Alusta mängu" Clicked="OnStartClicked"
                    Style="{DynamicResource GlobalButtonStyle}"/>

            <Grid x:Name="GameContainer"/>
        </VerticalStackLayout>

    </AbsoluteLayout>
</ContentPage>